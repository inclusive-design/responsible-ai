<!DOCTYPE html>
<html lang="{{ lang if lang else defaultLanguage }}-CA" dir="ltr">
<head>
  {% include 'partials/global/meta.njk' %}
  <title>{{ title }}</title>
  {% include "partials/global/stylesheets.njk" %}
  {% getBundle "fontawesome" %}
</head>
<body>
  {% include "partials/global/header.njk" %}
  <main id="main" class="{{ pageType if pageType else 'page' }}">
    {% block banner %}
    <div class="banner">
      <div class="wrapper">
        <div class="banner__content flow">
          {% if translationKey == 'processes' or translationKey == 'actions' or translationKey == 'site-map' or translationKey == 'glossary' %}
          {% set breadcrumbKeys = ['guidelines', title] %}
          {% set breadcrumbLinks = [] %}
          {% for breadcrumbKey in breadcrumbKeys %}
          {% if not loop.last %}
          {% set breadcrumb = collections['pages_' + lang] | find('data.translationKey', breadcrumbKey) %}
          {% set linkTitle = breadcrumb.data.shortTitle if breadcrumb.data.shortTitle else breadcrumb.data.title %}
          {% set breadcrumbLinks = breadcrumbLinks.concat({ 'title' : linkTitle, 'url' : breadcrumb.url }) %}
          {% endif %}
          {% if loop.last %}
              {% set lastLinkTitle = shortTitle if shortTitle else title %}
              {% set breadcrumbLinks = breadcrumbLinks.concat({ 'title' : lastLinkTitle, 'url' : url }) %}
          {% endif %}
          {% endfor %}
          {% include "partials/components/breadcrumb.njk" %}
          {% endif %}
          <h1>{{ title }}</h1>
          {% if bannerText %}
          {{ bannerText | renderContent('md') | safe }}
          {% endif %}
        </div>
        {% if bannerImage %}
        <div class="banner__image">
          <img src="{{ bannerImage }}" alt="{{ bannerImageAlt }}" />
        </div>
        {% endif %}
      </div>
        {% if pageType == 'guidelines' %}
          <div class="wrapper banner__nav">
            {% set link = (collections['pages_' + lang] | find('data.translationKey', 'risks')).url %}
            {% set buttonLabel = 'browse-risks' %}
            {% set isPrimary = false %}
            {% include "partials/components/link-button.njk" %}

            {% set link = (collections['pages_' + lang] | find('data.translationKey', 'benefits')).url %}
            {% set buttonLabel = 'browse-benefits' %}
            {% set isPrimary = false %}
            {% include "partials/components/link-button.njk" %}
          </div>
        {% endif %}
    </div>
    {% endblock %}
    <div class="content">
    {% block content %}
    <section>
      <div class="wrapper flow">
      {{ content | safe }}
      </div>
    </section>
    {% endblock %}
    </div>
  </main>
  {% include "partials/global/footer.njk" %}
  {% uioCustomInit lang, supportedLanguages[lang].dir %}
</body>
</html>
